{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@portaljs/core": ["custom_modules/core"],
      "@portaljs/remark-callouts": ["custom_modules/remark-callouts"],
      "@portaljs/remark-wiki-link": ["custom_modules/remark-wiki-link"],
      "@/*": ["./*"]
    },
    "target": "es2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "incremental": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve"
  },
  "include": ["types.d.ts", "next-env.d.ts", "**/*.tsx", "**/*.ts"],
  "exclude": ["node_modules"]
}